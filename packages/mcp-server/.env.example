# Storyblok MCP Server environment variables

# Required: Storyblok Preview API Token
# Get from: Storyblok Space > Settings > Access Tokens
STORYBLOK_API_TOKEN=your-preview-token

# Required: Storyblok Management API OAuth Token
# Get from: My Account > Personal access tokens
STORYBLOK_OAUTH_TOKEN=your-oauth-token

# Required: Storyblok Space ID
# Get from: Storyblok Space URL (e.g., app.storyblok.com/#/me/spaces/123456)
STORYBLOK_SPACE_ID=123456

# Optional: OpenAI API Key for AI content generation
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

MCP_PUBLIC_DOMAIN=your-domain.com

HOSTING_SERVER_IP=1.2.3.4

DOCKER_USERNAME=your-docker-user

DOCKER_MCP_IMAGE_NAME=your-org/your-image-name

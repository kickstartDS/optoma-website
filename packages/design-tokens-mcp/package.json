{
  "name": "@kickstartds/design-tokens-mcp",
  "version": "4.0.0",
  "description": "MCP server for managing design tokens from CSS/SCSS Custom Properties",
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "kickstartDS",
    "email": "info@kickstartds.com"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "design-tokens-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "tokens",
    "rules"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kickstartDS/storyblok-starter-premium.git",
    "directory": "packages/design-tokens-mcp"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "sync-tokens": "node sync-tokens.mjs",
    "build": "node sync-tokens.mjs && tsc",
    "dev": "node sync-tokens.mjs && tsc --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http MCP_PORT=8080 node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mcp",
    "design-tokens",
    "css-custom-properties",
    "design-system",
    "scss"
  ],
  "dependencies": {
    "@kickstartds/shared-auth": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

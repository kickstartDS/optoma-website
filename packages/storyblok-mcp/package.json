{
  "name": "@kickstartds/storyblok-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Storyblok CMS integration with kickstartDS Design System",
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "kickstartDS",
    "email": "info@kickstartds.com"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "storyblok-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/sync-schemas.js && node scripts/extract-tokens.js && node scripts/bundle-render.js && tsc && node scripts/bundle-render.js",
    "sync-schemas": "node scripts/sync-schemas.js",
    "build:tokens": "node scripts/extract-tokens.js",
    "build:render": "node scripts/bundle-render.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "test:ui": "NODE_OPTIONS='--experimental-vm-modules' npx jest --testPathPattern=test/ui"
  },
  "dependencies": {
    "@kickstartds/base": "^4.1.0",
    "@kickstartds/blog": "^4.1.0",
    "@kickstartds/content": "^4.1.1",
    "@kickstartds/core": "^4.1.0",
    "@kickstartds/design-system": "workspace:*",
    "@kickstartds/form": "^4.1.0",
    "@kickstartds/storyblok-services": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^28.1.0",
    "openai": "^6.18.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "storyblok-js-client": "^7.2.3",
    "turndown": "^7.2.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.19.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

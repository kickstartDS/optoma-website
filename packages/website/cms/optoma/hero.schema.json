        "sub": {
          "x-cms-hidden": false,
          "title": "Eine überschriebene Sub",
          "x-cms-order": 1
        },
        "text": {
          "x-cms-hidden": false,
          "title": "Ein überschriebener Text",
          "x-cms-order": 0
        },
        "colorNeutral": {
          "x-cms-hidden": true,

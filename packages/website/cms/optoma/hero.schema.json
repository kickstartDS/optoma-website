        },
        "invertText": {
          "x-cms-hidden": true,
          "x-cms-order": 8
        },
        "skipButton": {
          "x-cms-hidden": true,
          "x-cms-order": 10
        },
        "overlay": {
          "x-cms-hidden": true,
          "x-cms-order": 11

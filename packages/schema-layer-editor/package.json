{
  "name": "@kickstartds/schema-layer-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Visual editor for creating and editing JSON Schema layer files (visibility, title, description, order overrides)",
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "kickstartDS",
    "email": "info@kickstartds.com"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -P \"vite\" \"tsx watch src/cli.ts {@}\"",
    "start": "tsx src/cli.ts",
    "build": "vite build && tsc --project tsconfig.server.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "glob": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vite": "^5.1.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

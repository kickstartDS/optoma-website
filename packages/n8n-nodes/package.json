{
  "name": "n8n-nodes-storyblok-kickstartds",
  "version": "0.1.0",
  "description": "n8n community nodes for Storyblok CMS with kickstartDS – AI content generation and import",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "storyblok",
    "kickstartds",
    "cms",
    "content-generation",
    "openai"
  ],
  "license": "MIT",
  "author": {
    "name": "kickstartDS",
    "email": "info@kickstartds.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kickstartDS/storyblok-starter-premium.git",
    "directory": "packages/n8n-nodes"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/StoryblokApi.credentials.js",
      "dist/credentials/OpenAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/StoryblokKickstartDs/StoryblokKickstartDs.node.js"
    ]
  },
  "dependencies": {
    "@kickstartds/storyblok-services": "workspace:*",
    "openai": "^6.18.0",
    "storyblok-js-client": "^7.2.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

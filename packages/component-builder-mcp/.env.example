DOCKER_COMPONENT_BUILDER_MCP_IMAGE_NAME=
HOSTING_SERVER_IP=
COMPONENT_BUILDER_MCP_PUBLIC_DOMAIN=
DOCKER_USERNAME=

# Optional: JWT secret for HTTP transport authentication
# Generate with: node scripts/issue-token.mjs --generate-secret
# When unset, auth is disabled (suitable for local development)
# MCP_JWT_SECRET=

# Optional: Comma-separated JTI list to revoke specific tokens
# MCP_REVOKED_TOKENS=

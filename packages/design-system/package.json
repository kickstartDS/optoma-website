{
  "name": "@kickstartds/design-system",
  "version": "2.2.1",
  "description": "kickstartDS Design System — 80+ React components, design tokens, and Storybook",
  "homepage": "https://github.com/kickstartDS/storyblok-starter-premium#readme",
  "bugs": {
    "url": "https://github.com/kickstartDS/storyblok-starter-premium/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kickstartDS/storyblok-starter-premium.git",
    "directory": "packages/design-system"
  },
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "kickstartDS",
    "email": "info@kickstartds.com"
  },
  "sideEffects": [
    "**/*.client.ts",
    "**/*.client.js",
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./static/*": "./dist/static/*",
    "./tokens/*": "./dist/tokens/*",
    "./icon-sprite": "./dist/tokens/IconSprite.js",
    "./playground/*": {
      "types": "./dist/playground/*/index.d.ts",
      "default": "./dist/playground/*/index.js"
    },
    "./pages/*": {
      "types": "./dist/pages/*/index.d.ts",
      "default": "./dist/pages/*/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./*.json": "./dist/components/*.json",
    "./cms/*.schema.json": "./dist/cms/*.schema.json",
    "./*": {
      "types": "./dist/components/*/index.d.ts",
      "default": "./dist/components/*/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && pnpm run build-tokens && pnpm run schema && pnpm run token && pnpm run branding-tokens && rollup -c && tsc --emitDeclarationOnly --noCheck -p tsconfig.build.json && node scripts/generateDtsBarrels.mjs && pnpm run presets && cp snippets.json dist/components/presets.json",
    "prepack": "pnpm run build",
    "build-storybook": "pnpm run build-tokens && pnpm run schema && pnpm run token && pnpm run search && pnpm run copy-theme-css && storybook build",
    "copy-theme-css": "mkdir -p static/tokens && cp src/token/branding-tokens*.css static/tokens/",
    "build-tokens": "kickstartDS tokens compile",
    "chromatic": "chromatic --build-script-name \"build-storybook\" --output-dir \"storybook-static\" --skip \"@(renovate/**|dependabot/**)\" --exit-zero-on-changes --exit-once-uploaded",
    "init-tokens": "kickstartDS tokens init",
    "playroom": "run-p watch:* playroom:start",
    "playroom:start": "playroom start",
    "playroom:build": "playroom build",
    "presets": "vitest run scripts/generatePresets.test.ts",
    "search": "rm -rf static/pagefind && vitest run scripts/generateSearchIndex.test.ts",
    "schema": "run-p schema:*",
    "schema:dereference-schemas": "kickstartDS schema dereference",
    "schema:generate-props": "kickstartDS schema types",
    "schema:layer-types": "kickstartDS schema layer",
    "schema:create-defaults": "kickstartDS schema defaults",
    "start": "run-p watch:* storybook",
    "storybook": "pnpm run copy-theme-css && storybook dev -p 6006",
    "create-component-previews": "pnpm run test && rimraf static/img/screenshots && mkdir -p static/img/screenshots && cp __snapshots__/*.png static/img/screenshots",
    "test": "rimraf __snapshots__ && run-p -r test:*",
    "test:server": "npx http-server storybook-static --port 6006 --silent",
    "test:suite": "npx wait-on http://127.0.0.1:6006 && test-storybook --maxWorkers=8",
    "token": "node scripts/customPropertyExtract.cjs",
    "branding-tokens": "node scripts/buildBrandingTokens.mjs",
    "typecheck": "tsc --noEmit",
    "watch:schema": "pnpm run schema && chokidar \"src/**/*.schema.json\" -c \"pnpm run schema\"",
    "watch:token": "pnpm run token && chokidar \"src/**/*-tokens.scss\" -c \"pnpm run token {path}\"",
    "watch:branding-tokens": "pnpm run branding-tokens && chokidar \"src/token/branding-tokens{,-*}.json\" -c \"pnpm run branding-tokens {path}\"",
    "watch:dictionary": "pnpm run build-tokens && chokidar \"src/token/dictionary/*.json\" -c \"pnpm run build-tokens\""
  },
  "dependencies": {
    "@bedrock-layout/primitives": "^3.0.23",
    "@bedrock-layout/spacing-constants": "^3.2.5",
    "classnames": "^2.3.2",
    "markdown-to-jsx": "^7.5.0"
  },
  "devDependencies": {
    "@kickstartds/base": "^4.1.0",
    "@kickstartds/blog": "^4.1.0",
    "@kickstartds/content": "^4.1.1",
    "@kickstartds/core": "^4.1.0",
    "@kickstartds/form": "^4.1.0",
    "@kickstartds/jsonschema-utils": "^3.8.1",
    "@kickstartds/jsonschema2types": "^1.2.7",
    "@kickstartds/storybook-addon-component-tokens": "^3.0.0",
    "@kickstartds/storybook-addon-html": "^1.0.0",
    "@kickstartds/storybook-addon-jsonschema": "^4.0.0",
    "@kickstartds/style-dictionary": "^4.0.2",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-json": "^6.1.0",
    "@storybook/addon-a11y": "^10.2.0-beta.1",
    "@storybook/addon-docs": "^10.2.0-beta.1",
    "@storybook/addon-links": "^10.2.0-beta.1",
    "@storybook/addon-mcp": "^0.1.8",
    "@storybook/react-vite": "^10.2.0-beta.1",
    "@storybook/test-runner": "^0.24.2",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.11",
    "@types/jest-image-snapshot": "^6.4.0",
    "@types/react": "^19.2.7",
    "@vitejs/plugin-react": "^4.2.1",
    "c15t": "^1.5.0",
    "change-case": "^4.1.2",
    "chokidar-cli": "^3.0.0",
    "chromatic": "^6.24.1",
    "copy-webpack-plugin": "^11.0.0",
    "custom-property-extract": "^1.2.1",
    "deepmerge": "^4.3.1",
    "fast-glob": "^3.3.1",
    "fs-extra": "^11.1.1",
    "ajv": "^8.12.0",
    "happy-dom": "^13.3.1",
    "jest-image-snapshot": "^6.4.0",
    "kickstartds": "3.5.0--canary.62.324.0",
    "lazysizes": "^5.3.2",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.4.0",
    "playroom": "^1.2.1",
    "postcss": "^8.4.29",
    "postcss-url": "^10.1.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "rollup": "^4.53.3",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-node-externals": "^8.1.2",
    "sass": "^1.66.1",
    "sass-loader": "^13.3.3",
    "storybook": "^10.2.0-beta.1",
    "storybook-addon-playroom": "^8.0.0",
    "storybook-design-token": "^5.0.0",
    "style-loader": "^3.3.3",
    "traverse": "^0.6.11",
    "typescript": "^5.2.2",
    "vitest": "^1.2.1"
  },
  "peerDependencies": {
    "@kickstartds/base": "^4.0.2",
    "@kickstartds/blog": "^4.0.2",
    "@kickstartds/content": "^4.1.1",
    "@kickstartds/core": "^4.0.2",
    "@kickstartds/form": "^4.0.2",
    "c15t": "^1.5.0",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19",
    "tinycolor2": "^1.6.0",
    "traverse": "^0.6.11"
  },
  "peerDependenciesMeta": {
    "c15t": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

# Design System (Storybook) deployment environment variables
# Used by Kamal via config/deploy-design-system.yml

# Required: Docker image name for the Storybook container
# Example: ghcr.io/your-org/design-system-storybook
DOCKER_STORYBOOK_IMAGE_NAME=your-org/design-system-storybook

# Required: Docker registry username
DOCKER_USERNAME=your-docker-user

# Required: IP address of the hosting server
HOSTING_SERVER_IP=1.2.3.4

# Required: Public domain for the Storybook site (SSL auto-provisioned via Let's Encrypt)
STORYBOOK_PUBLIC_DOMAIN=storybook.your-domain.com

STORYBLOK_API_TOKEN=your-preview-token

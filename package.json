{
  "name": "@kickstartds/storyblok-starter-premium-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r run build",
    "dev:web": "pnpm --filter website dev",
    "dev:mcp": "pnpm --filter mcp-server dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "layer-editor": "bash -c 'ROOT=$PWD && LAYER=${0:-visibility} && pnpm --filter schema-layer-editor dev --schemas $ROOT/packages/website/node_modules/@kickstartds/ds-agency-premium/dist/components --schemas-extra $ROOT/packages/website/components --namespace $LAYER --layer $ROOT/packages/website/cms/$LAYER'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@kickstartds/base@4.2.0": "patches/@kickstartds__base@4.2.0.patch"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "fsevents",
      "protobufjs",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@modelcontextprotocol/ext-apps"
    ]
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://cms.mydesignsystem.com/timeline.schema.json",
  "title": "Timeline",
  "description": "A vertical timeline component displaying chronological events with years, descriptions, and optional images",
  "type": "object",
  "properties": {
    "timelineItems": {
      "type": "array",
      "title": "Timeline Items",
      "description": "Array of timeline entries/events",
      "items": {
        "type": "object",
        "properties": {
          "year": {
            "type": "string",
            "title": "Year",
            "description": "The year or date for this timeline entry"
          },
          "textLeft": {
            "type": "string",
            "title": "Left Text",
            "description": "Text content displayed on the left side of the timeline",
            "format": "markdown"
          },
          "textRight": {
            "type": "string",
            "title": "Right Text",
            "description": "Text content displayed on the right side of the timeline",
            "format": "markdown"
          },
          "image": {
            "type": "object",
            "title": "Image",
            "description": "Optional image for this timeline entry",
            "properties": {
              "src": {
                "type": "string",
                "title": "Image Source",
                "description": "URL of the image",
                "format": "image"
              },
              "alt": {
                "type": "string",
                "title": "Alt Text",
                "description": "Alternative text for the image"
              }
            }
          }
        },
        "required": ["year"]
      }
    }
  },
  "required": ["timelineItems"],
  "additionalProperties": false
}
